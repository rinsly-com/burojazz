# Payload secret — used to sign auth tokens. Generate with: openssl rand -hex 32
PAYLOAD_SECRET=

# The D1 database and (optional) R2 bucket are provided by Cloudflare Worker
# bindings configured in wrangler.jsonc — there is no DATABASE_URL here.

# Origin of the Payload API the static frontend fetches published content from.
# Local dev: http://localhost:3000. Static prod build: the accp URL.
PAYLOAD_API_URL=http://localhost:3000

# Cloudflare Deploy Hook that rebuilds the static production site. Set this on
# the accp Worker (as a secret) so publishing content triggers a prod rebuild.
# CLOUDFLARE_DEPLOY_HOOK_URL=

# Optional: log level for the production (Workers) logger — trace|debug|info|warn|error
# PAYLOAD_LOG_LEVEL=info
